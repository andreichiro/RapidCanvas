# Keep local-only files, caches, and generated artifacts out of Docker builds.
.git
.env
.env.*
!.env.example
.DS_Store

backend/.venv
backend/.cache
backend/.mypy_cache
backend/.pytest_cache
backend/.ruff_cache
backend/mlruns
backend/qdrant_storage

frontend/node_modules
frontend/dist
frontend/coverage

mlruns
qdrant_storage
reports/*
!reports/.gitkeep
