# Copy this file to .env locally. Never commit .env.
# The provided assignment API key belongs in local .env only and should be rotated
# because it was shared in plain text during project intake.

APP_ENV=local
LOG_LEVEL=INFO

OPENAI_API_KEY=
DSPY_MODEL=openai/gpt-4.1-mini
DSPY_JUDGE_MODEL=openai/gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
VISION_MODEL=gpt-4.1-mini

ENABLE_IMAGE_UNDERSTANDING=false
ENABLE_HF_RERANKER=false

MLFLOW_TRACKING_URI=file:./mlruns
QDRANT_PATH=.cache/qdrant
REPORTS_DIR=reports

# Optional providers for later phases. Missing keys must cause graceful skips.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

